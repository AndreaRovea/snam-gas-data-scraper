# Copy to .env and fill values as needed.
# .env is git-ignored.

# Base URL of the Snam public portal (override if it changes).
SNAM_BASE_URL=https://www.snam.it

# Optional: custom User-Agent string for HTTP requests.
# SCRAPER_USER_AGENT="snam-gas-data-scraper/0.1 (+https://github.com/AndreaRovea/snam-gas-data-scraper)"

# Optional: HTTP request timeout in seconds.
# SCRAPER_TIMEOUT_SECONDS=15

# Optional: log level (DEBUG, INFO, WARNING, ERROR).
# LOG_LEVEL=INFO
